        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-simplon-rag"
          },
          "expr": "histogram_quantile(0.50, sum by (le, node) (rate(rag_node_duration_seconds_bucket{job=\"simplon-rag-api\"}[$__rate_interval])))",
          "legendFormat": "p50 {{node}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-simplon-rag"
          },
          "expr": "histogram_quantile(0.95, sum by (le, node) (rate(rag_node_duration_seconds_bucket{job=\"simplon-rag-api\"}[$__rate_interval])))",
          "legendFormat": "p95 {{node}}",
          "refId": "B"
        }
      ],
      "title": "Latence par nœud — p50 / p95",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "id": 102,
      "title": "🗄️ Infrastructure",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-simplon-rag"
      },
      "description": "Cibles Prometheus actuellement UP",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 28
      },
      "id": 7,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-simplon-rag"
          },
          "expr": "count(up{job=\"simplon-rag-api\"} == 1)",
